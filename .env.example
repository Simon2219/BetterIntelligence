# BetterIntelligence Configuration - Copy to .env and adjust as needed

# Server
PORT=3000
HOST=localhost
NODE_ENV=development
# Set USE_HTTPS=1 for HTTPS; or use npm run start:https
USE_HTTPS=0

# Database
DB_PATH=./data/db/betterintelligence.db

# Media
MEDIA_PATH=./data/media

# Auth / JWT (change in production)
JWT_ACCESS_SECRET=bi-dev-access-secret-change-in-production
JWT_REFRESH_SECRET=bi-dev-refresh-secret-change-in-production

# Security / CORS / Socket origin controls
# Comma-separated origins (example): https://app.example.com,https://admin.example.com
SECURITY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
HTTP_CORS_ORIGINS=*
SOCKET_CORS_ORIGINS=*
SECURITY_ACCEPT_SOCKET_QUERY_TOKEN=true
SECURITY_ALLOW_NO_ORIGIN_IN_DEV=true

# Logging
LOG_ENABLED=1
LOG_LEVEL=info
LOG_CONSOLE=1
LOG_FILE=1
LOG_PATH=./data/logs

# AI
AI_ENABLED=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=huihui_ai/qwen2.5-abliterate:7b
COMFYUI_URL=http://localhost:8188
COMFYUI_MODEL=flux2_dev_fp8mixed.safetensors
# Start ComfyUI automatically with the server (requires comfyui/ folder or COMFYUI_PATH)
COMFYUI_START_WITH_SERVER=1
# Use RealChat's ComfyUI (when both projects exist on same machine):
# COMFYUI_PATH=../RealChat/RealChat/comfyui
# Or absolute: COMFYUI_PATH=S:\Projects\RealChat\RealChat\comfyui
# Optional: COMFYUI_VRAM_MODE=lowvram|novram|normal (default: lowvram)

# Admin seed (first run only)
ADMIN_EMAIL=admin@betterintelligence.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminPass123!
